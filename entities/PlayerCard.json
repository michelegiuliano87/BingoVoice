{
  "name": "PlayerCard",
  "type": "object",
  "properties": {
    "card_number": {
      "type": "number",
      "description": "Numero della cartella (es. 1, 2, 3...)"
    },
    "image_url": {
      "type": "string",
      "description": "URL dell'immagine della cartella"
    },
    "media_item_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
